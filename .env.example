# RouterForge environment variables
# Copy to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_NAME=RouterForge
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth
AUTH_SECRET=replace-with-32-char-random-string
AUTH_TRUST_HOST=true

# Database (dev: sqlite; prod: Postgres / MySQL)
DATABASE_URL="file:./dev.db"

# CLIProxyAPI Plus (backend router/proxy layer)
CLIPROXY_BASE_URL=https://api.cliproxy.example
CLIPROXY_ADMIN_TOKEN=
CLIPROXY_DEFAULT_TIMEOUT_MS=60000

# Provider API keys (managed through CLIProxyAPI in production)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Payment gateways
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET=
BYBIT_PAY_API_KEY=
BYBIT_PAY_SECRET=

# Crypto payment webhook shared secret
CRYPTO_WEBHOOK_SECRET=

# Email / notifications (optional)
RESEND_API_KEY=
EMAIL_FROM="RouterForge <noreply@routerforge.example>"

# Admin bootstrap (used by seed script)
ADMIN_BOOTSTRAP_EMAIL=admin@routerforge.example
ADMIN_BOOTSTRAP_PASSWORD=changeme-now
