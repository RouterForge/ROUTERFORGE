# RouterForge environment variables
# Copy to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_NAME=RouterForge
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth
AUTH_SECRET=replace-with-32-char-random-string
AUTH_TRUST_HOST=true

# Database (dev: sqlite; prod: Postgres / MySQL)
DATABASE_URL="file:./dev.db"

# CLIProxyAPI Plus (backend router/proxy layer)
CLIPROXY_BASE_URL=https://api.cliproxy.example
CLIPROXY_ADMIN_TOKEN=
CLIPROXY_DEFAULT_TIMEOUT_MS=60000

# Provider API keys (managed through CLIProxyAPI in production)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Payment gateways
POLAR_API_KEY=
POLAR_API_URL=https://api.polar.sh
POLAR_WEBHOOK_SECRET=
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET=
BINANCE_PAY_BASE=https://bpay.binanceapi.com
BYBIT_PAY_API_KEY=
BYBIT_PAY_SECRET=
BYBIT_PAY_BASE=https://api.bybit.com

# On-chain crypto payments (deposit addresses + webhook signing)
CRYPTO_WEBHOOK_SECRET=
CRYPTO_ADDRESS_USDT=
CRYPTO_ADDRESS_USDC=
CRYPTO_ADDRESS_BTC=
CRYPTO_ADDRESS_ETH=

# Email / notifications (optional)
RESEND_API_KEY=
EMAIL_FROM="RouterForge <noreply@routerforge.example>"

# Bootstrap accounts (used by seed script). Change these before any real launch.
# Quote any password containing `#` so dotenv doesn't treat the rest as a comment.
ADMIN_BOOTSTRAP_EMAIL=admin@routerforge.io
ADMIN_BOOTSTRAP_PASSWORD="Admin#2025!"
USER_BOOTSTRAP_EMAIL=demo@routerforge.io
USER_BOOTSTRAP_PASSWORD="Demo#2025!"
